rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /events/{eventId}/photos/{fileName} {
      allow read: if true;
      allow write, delete: if false;
    }

    match /events/{eventId}/hero/{fileName} {
      allow read: if true;
      allow write, delete: if false;
    }

    match /{file=**} {
      allow read, write: if false;
    }
  }
}
